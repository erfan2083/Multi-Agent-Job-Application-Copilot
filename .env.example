# LLM Provider: "claude" (browser session) or "openai" / "chatgpt" (API key)
LLM_PROVIDER=claude

# Claude Session (login credentials for claude.ai — used when LLM_PROVIDER=claude)
CLAUDE_EMAIL=your@email.com
CLAUDE_PASSWORD=yourpassword

# OpenAI / ChatGPT (used when LLM_PROVIDER=openai or chatgpt)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional: Job site credentials for Phase 3 auto-apply
JOBINJA_EMAIL=
JOBINJA_PASSWORD=
IRANTALENT_EMAIL=
IRANTALENT_PASSWORD=
WELLFOUND_EMAIL=
WELLFOUND_PASSWORD=

# Settings
MIN_MATCH_SCORE=60
MAX_JOBS_PER_SITE=20
REQUEST_DELAY_SECONDS=2
DATABASE_URL=sqlite:///./job_hunter.db
